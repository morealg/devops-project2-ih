services:
  db:
    image: postgres:15
    container_name: "{{ sonarqube_postgres_container }}"
    environment:
      POSTGRES_USER: "{{ sonarqube_postgres_user }}"
      POSTGRES_PASSWORD: "{{ sonarqube_postgres_password }}"
      POSTGRES_DB: "{{ sonarqube_postgres_db }}"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - sonarqube

  sonarqube:
    image: sonarqube:community
    container_name: "{{ sonarqube_container }}"
    depends_on:
      - db
    ports:
      - "{{ sonarqube_port }}:9000"
    environment:
      SONAR_JDBC_URL: "jdbc:postgresql://db:5432/{{ sonarqube_postgres_db }}"
      SONAR_JDBC_USERNAME: "{{ sonarqube_postgres_user }}"
      SONAR_JDBC_PASSWORD: "{{ sonarqube_postgres_password }}"
    volumes:
      - sonarqube_data:/opt/sonarqube/data
      - sonarqube_logs:/opt/sonarqube/logs
      - sonarqube_extensions:/opt/sonarqube/extensions
    networks:
      - sonarqube

volumes:
  postgres_data:
  sonarqube_data:
  sonarqube_logs:
  sonarqube_extensions:

networks:
  sonarqube:
    name: "{{ sonarqube_network }}"
